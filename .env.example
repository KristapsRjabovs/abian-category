# Local development needs a Postgres URL. The simplest option is to copy the
# NETLIFY_DATABASE_URL or NETLIFY_DATABASE_URL_UNPOOLED value from the Netlify
# dashboard (Site → Extensions → Neon → Environment variables) into here.
#
# On Netlify itself the variable is injected automatically, so .env is only
# needed for local Flask runs.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require
